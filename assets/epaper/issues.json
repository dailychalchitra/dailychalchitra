---
layout: null
permalink: /assets/epaper/issues/issues.json
---
[
{% assign posts_by_week = site.posts | group_by_exp: "post", "post.date | date: '%Y-W%V'" | sort: "name" | reverse %}
{% for week in posts_by_week %}
{
  "id": "{{ week.name }}",
  "year": "{{ week.name | slice: 0, 4 }}",
  "week": "{{ week.name | slice: 6, 2 }}",
  "title": "দৈনিক চালচিত্র – সপ্তাহ {{ week.name | slice: 6, 2 }}, {{ week.name | slice: 0, 4 }}",
  "date": "{{ week.items.first.date | date: '%Y-%m-%d' }}",
  "pages": {{ week.items.size | divided_by: 6.0 | ceil }},
  "count": {{ week.items.size }},
  "viewer": "/epaper/viewer/?issue={{ week.name }}"
}{% unless forloop.last %},{% endunless %}
{% endfor %}
]
